# Anthropic API key for Claude inference via Vercel AI SDK
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vapi API key for fetching call data by call ID
VAPI_API_KEY=your_vapi_api_key_here

# Secret used to verify Vapi webhook signatures (optional but recommended)
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
